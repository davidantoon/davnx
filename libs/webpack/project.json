{
  "name": "webpack",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/webpack/src",
  "projectType": "library",
  "targets": {
    "build": {
      "dependsOn": ["compile"],
      "command": "node -e \"const fs=require('fs'),j=JSON.parse(fs.readFileSync('libs/webpack/executors.json','utf8'));for(const e of Object.values(j.executors)){e.implementation=e.implementation.replace('./src/','./');e.schema=e.schema.replace('./src/','./');};fs.writeFileSync('dist/libs/webpack/executors.json',JSON.stringify(j,null,2)+'\\n')\""
    },
    "compile": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/webpack",
        "tsConfig": "libs/webpack/tsconfig.lib.json",
        "main": "libs/webpack/src/index.ts",
        "rootDir": "libs/webpack/src",
        "assets": [
          "libs/webpack/README.md",
          {
            "input": "libs/webpack",
            "glob": "package.json",
            "output": "."
          },
          {
            "input": "libs/webpack/src",
            "glob": "**/*.json",
            "output": "."
          },
          {
            "input": "libs/webpack/src",
            "glob": "**/schema.d.ts",
            "output": "."
          }
        ]
      }
    }
  }
}
